# ---------------------------------------------------------------------------
# Copie ce fichier en  deploy/deploy.env  et remplis tes accès.
# deploy/deploy.env est gitignoré : tes identifiants ne partent JAMAIS sur Git.
# ---------------------------------------------------------------------------

# Accès FTP/SFTP de ton hébergement
FTP_HOST="ftp.atelierby.online"
FTP_USER="ton_utilisateur"
FTP_PASS="ton_mot_de_passe"

# Protocole : "ftp" (port 21) ou "sftp" (port 22)
FTP_PROTO="ftp"
FTP_PORT="21"

# Racine du webshop sur le serveur (là où sont servis /webshop/assets et /webshop/api)
# Souvent quelque chose comme /httpdocs/webshop, /public_html/webshop, /www/webshop…
REMOTE_WEBROOT="/var/www/html/webshop"

# FTP en clair : mettre "yes" pour forcer TLS si l'hébergeur le supporte (recommandé)
FTP_TLS="no"
