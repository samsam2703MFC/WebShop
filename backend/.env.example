# ── Webshop dedicated database (read/write) ─────────────────────────
WEBSHOP_DB_HOST=localhost
WEBSHOP_DB_PORT=3306
WEBSHOP_DB_USER=webshop
WEBSHOP_DB_PASSWORD=change-me
WEBSHOP_DB_NAME=webshop

# ── General / ERP database "Franchise Buddy" (READ + outbox only) ───
# The webshop never writes to general tables; the sync worker reads
# source tables and consumes/marks rows in the outbox table only.
GENERAL_DB_HOST=localhost
GENERAL_DB_PORT=3306
GENERAL_DB_USER=webshop
GENERAL_DB_PASSWORD=change-me
GENERAL_DB_NAME=franchise_buddy

# ── HTTP server ──────────────────────────────────────────────────────
PORT=3001
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=https://samsam2703mfc.github.io,http://localhost:8080
# Shared secret guarding admin/provisioning endpoints (POST/PATCH /admin/shops).
# Send it as `Authorization: Bearer <token>` or `X-Admin-Token: <token>`.
ADMIN_TOKEN=change-me-long-random
# Secret signing the customer session tokens (/auth). Long & random.
AUTH_SECRET=change-me-long-random

# ── Stripe ───────────────────────────────────────────────────────────
# Use sk_test_* / whsec_* in test mode; swap to live keys at go-live.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Where Stripe Checkout redirects the customer afterwards
CHECKOUT_SUCCESS_URL=https://samsam2703mfc.github.io/WebShop/webshop-full.html?order={ORDER_ID}&paid=1
CHECKOUT_CANCEL_URL=https://samsam2703mfc.github.io/WebShop/webshop-full.html?order={ORDER_ID}&canceled=1

# ── Sync worker ──────────────────────────────────────────────────────
SYNC_POLL_MS=1000
SYNC_BATCH_SIZE=200
